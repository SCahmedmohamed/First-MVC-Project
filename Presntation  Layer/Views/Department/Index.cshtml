@model IEnumerable<Department>  
@{
    ViewData["Title"] = "Index";
}

<h1>All Departments</h1>


<br />
<br />
<a asp-action="Create" class="btn btn-secondary">Create Department</a>
<br />
<br />

<form>
    <div class="container ">
        <div class="row">
            <div class="col-6 ">
                <input type="text" name="searchInput" class="form-control" placeholder="Search By Name" />
            </div>
            <div class="col-6">
                <input type="submit" value="Search" class="btn btn-success" asp-action="Index" />
            </div>
        </div>
    </div>
</form>


@if(Model is not null && Model.Any())
{
    <table class=" table table-hover table-striped">
        <thead>
            <tr>    
                <th>Code</th> 
                <th>Name</th>
                <th>Creation Date</th> 
                <th>Details</th>
                <th>Update</th>
                <th>Delete</th>
            </tr>
        </thead>
        <tbody>
            @foreach(var item in Model)
            {
                <tr> 
                    <td> @item.Code</td>
                    <td> @item.Name</td>
                    <td> @item.CreatedAt</td>
                    <td>
                        <a asp-action="Details" class=" btn btn-warning" asp-route-id ="@item.Id" >Details</a>

                    </td>
                    <td>
                        <a asp-action="Update" class=" btn btn-success" asp-route-id="@item.Id" >Update</a>
                    </td>
                    <td>
                        <a asp-action="Delete" class=" btn btn-danger" asp-route-id="@item.Id" >Delete</a>
                    </td>
                </tr>
            }
        </tbody>

    </table>
}
else
{
    <div class="mt-4 alert alert-info">
        <h4>There're Not Any Department</h4>
    </div>
}

